<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cozynote.ui.shell.MainController"
            stylesheets="@../styles/cozy.css"
            styleClass="app-shell">
    <top>
        <VBox>
            <MenuBar styleClass="top-menu">
                <menus>
                    <Menu text="파일">
                        <items>
                            <MenuItem text="열기"/>
                            <MenuItem fx:id="exportMenuItem" text="백업 내보내기"/>
                            <MenuItem fx:id="importMenuItem" text="백업 불러오기"/>
                            <MenuItem fx:id="closeMenuItem" text="종료"/>
                        </items>
                    </Menu>
                    <Menu text="보기">
                        <items>
                            <MenuItem fx:id="toggleLeftSidebarMenuItem" text="사이드바 숨김"/>
                            <MenuItem fx:id="toggleRightPanelMenuItem" text="오른쪽 패널 숨김"/>
                        </items>
                    </Menu>
                    <Menu text="도구">
                        <items>
                            <MenuItem fx:id="settingsMenuItem" text="설정"/>
                        </items>
                    </Menu>
                    <Menu text="도움말">
                        <items>
                            <MenuItem fx:id="helpMenuItem" text="사용 설명서"/>
                        </items>
                    </Menu>
                </menus>
            </MenuBar>
            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="panel-toggle-bar">
                <padding>
                    <Insets top="6" right="18" bottom="6" left="18"/>
                </padding>
                <Button fx:id="leftPanelToggleButton" text="사이드바 숨김" styleClass="toolbar-button"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="rightPanelToggleButton" text="오른쪽 패널 숨김" styleClass="toolbar-button"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox fx:id="appBody" spacing="16" styleClass="app-body">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>
            <fx:include fx:id="sidebarPane" source="sidebar.fxml"/>
            <fx:include fx:id="editorPane" source="editor.fxml" HBox.hgrow="ALWAYS"/>
            <fx:include fx:id="rightPanelPane" source="music-player.fxml"/>
        </HBox>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="status-bar">
            <padding>
                <Insets top="8" right="18" bottom="8" left="18"/>
            </padding>
            <Label fx:id="statusLabel" id="statusLabel"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </bottom>
</BorderPane>
