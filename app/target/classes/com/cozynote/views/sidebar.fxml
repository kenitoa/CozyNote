<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox minWidth="320"
      prefWidth="320"
      maxWidth="320"
      spacing="18"
      styleClass="sidebar"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cozynote.ui.sidebar.SidebarController">
    <Button fx:id="newMemoButton" maxWidth="Infinity" text="+ 새 메모" styleClass="primary-button"/>
    <TextField fx:id="searchField" promptText="검색" styleClass="search-field"/>

    <VBox spacing="8" styleClass="side-section" VBox.vgrow="ALWAYS">
        <Label text="최근 메모" styleClass="section-title"/>
        <ListView fx:id="recentNoteListView" prefHeight="210" styleClass="side-list" VBox.vgrow="ALWAYS"/>
    </VBox>

    <VBox spacing="8" styleClass="side-section" VBox.vgrow="ALWAYS">
        <Label text="즐겨찾기" styleClass="section-title"/>
        <ListView fx:id="favoriteNoteListView" prefHeight="130" styleClass="side-list" VBox.vgrow="ALWAYS"/>
    </VBox>

    <VBox spacing="8" styleClass="side-section" VBox.vgrow="ALWAYS">
        <Label text="카테고리" styleClass="section-title"/>
        <ListView fx:id="categoryListView" prefHeight="170" styleClass="category-list" VBox.vgrow="ALWAYS"/>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>
    <Label fx:id="sidebarStatusLabel" text="" wrapText="true" maxWidth="Infinity" styleClass="sidebar-status"/>
    <Button fx:id="settingsButton" text="설정" styleClass="settings-link"/>
</VBox>
