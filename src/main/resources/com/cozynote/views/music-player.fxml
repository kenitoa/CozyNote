<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="widgetRoot" minWidth="420" prefWidth="420" maxWidth="420" spacing="14" styleClass="widget-panel" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cozynote.ui.widgets.MusicPlayerController">
    <VBox spacing="12" styleClass="widget-card">
        <Label text="&#51020;&#50501; &#54540;&#47112;&#51060;&#50612;" styleClass="widget-title"/>
        <StackPane prefWidth="388" prefHeight="388" minWidth="388" minHeight="388" maxWidth="388" maxHeight="388" styleClass="album-art-frame">
            <ImageView fx:id="albumImageView" fitWidth="388" fitHeight="388" preserveRatio="false" smooth="true"/>
        </StackPane>
        <Label fx:id="titleLabel" styleClass="track-title"/>
        <Label fx:id="artistLabel" styleClass="muted"/>
        <Slider fx:id="progressSlider" min="0" max="1"/>
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label fx:id="elapsedLabel" styleClass="muted"/>
            <Label text="/" styleClass="muted"/>
            <Label fx:id="durationLabel" styleClass="muted"/>
        </HBox>
        <HBox alignment="CENTER" spacing="10">
            <Button fx:id="trackListButton" text="&#8801;" onAction="#openTrackList" styleClass="repeat-mode-button"/>
            <Button text="&#9198;" onAction="#previousTrack" styleClass="toolbar-button"/>
            <Button fx:id="playButton" text="&#9654;" onAction="#togglePlay" styleClass="primary-button"/>
            <Button text="&#9197;" onAction="#nextTrack" styleClass="toolbar-button"/>
            <Button fx:id="repeatModeButton" text="&#8734;" onAction="#cycleRepeatMode" styleClass="repeat-mode-button"/>
        </HBox>
        <Slider fx:id="volumeSlider" min="0" max="1"/>
    </VBox>
    <VBox spacing="12" styleClass="widget-card empty-widget-card">
        <Label text="&#48120;&#45768; &#44172;&#51076; &#54056;&#45328;" styleClass="widget-title"/>
        <StackPane fx:id="miniGameContainer"
                   minHeight="400"
                   prefHeight="400"
                   maxHeight="400"
                   styleClass="empty-widget-body"/>
    </VBox>
</VBox>
