<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<BorderPane minWidth="760" maxWidth="Infinity" styleClass="editor-card notepad-editor" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cozynote.ui.editor.EditorController">
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="editor-header">
                <TextField fx:id="titleField" promptText="제목 없음" styleClass="memo-title-field" HBox.hgrow="ALWAYS"/>
            </HBox>
            <ScrollPane fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" styleClass="notepad-toolbar-scroll">
                <content>
                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="notepad-command-bar">
                        <HBox alignment="CENTER_LEFT" spacing="6" styleClass="notepad-tool-group">
                            <Label text="&#53581;&#49828;&#53944;" styleClass="notepad-group-label"/>
                            <Label text="&#53356;&#44592;" styleClass="stat-label"/>
                            <ComboBox fx:id="fontSizeComboBox" onAction="#changeFontSize" prefWidth="76" styleClass="notepad-font-size"/>
                            <Label text="&#44544;&#51088;" styleClass="stat-label"/>
                            <ColorPicker fx:id="fontColorPicker" onAction="#changeFontColor" styleClass="notepad-color-picker"/>
                            <Label text="&#54805;&#44305;" styleClass="stat-label"/>
                            <ColorPicker fx:id="highlightColorPicker" onAction="#changeHighlight" styleClass="notepad-color-picker"/>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="6" styleClass="notepad-tool-group">
                            <Label text="&#49436;&#49885;" styleClass="notepad-group-label"/>
                            <Button text="U" onAction="#applyUnderline" styleClass="toolbar-button notepad-format-command">
                            <tooltip><Tooltip text="&#49440;&#53469;&#32;&#50689;&#50669;&#32;&#48145;&#51460;"/></tooltip>
                        </Button>
                            <Button text="S" onAction="#applyStrike" styleClass="toolbar-button notepad-format-command">
                            <tooltip><Tooltip text="&#49440;&#53469;&#32;&#50689;&#50669;&#32;&#52712;&#49548;&#49440;"/></tooltip>
                        </Button>
                            <Button text="X&#8321;" onAction="#applySubscript" styleClass="toolbar-button notepad-format-command">
                            <tooltip><Tooltip text="&#49440;&#53469;&#32;&#50689;&#50669;&#32;&#50500;&#47000;&#52392;&#51088;"/></tooltip>
                        </Button>
                            <Button text="X&#178;" onAction="#applySuperscript" styleClass="toolbar-button notepad-format-command">
                            <tooltip><Tooltip text="&#49440;&#53469;&#32;&#50689;&#50669;&#32;&#50948;&#52392;&#51088;"/></tooltip>
                        </Button>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="6" styleClass="notepad-tool-group">
                            <Label text="&#51221;&#47532;" styleClass="notepad-group-label"/>
                            <ComboBox fx:id="alignmentComboBox" promptText="&#51221;&#47148;" onAction="#changeAlignment" prefWidth="88" styleClass="notepad-align-menu"/>
                            <Button text="1." onAction="#applyNumbering" styleClass="toolbar-button notepad-format-command">
                            <tooltip><Tooltip text="&#48264;&#54840;&#32;&#47588;&#44592;&#44592;"/></tooltip>
                        </Button>
                            <Button text="&#8594;" onAction="#indentLines" styleClass="toolbar-button notepad-format-command">
                            <tooltip><Tooltip text="&#46308;&#50668;&#50416;&#44592;"/></tooltip>
                        </Button>
                            <Button text="&#8592;" onAction="#outdentLines" styleClass="toolbar-button notepad-format-command">
                            <tooltip><Tooltip text="&#45236;&#50612;&#50416;&#44592;"/></tooltip>
                        </Button>
                            <Button text="&#9633;" onAction="#toggleCheckboxLines" styleClass="toolbar-button notepad-format-command">
                            <tooltip><Tooltip text="&#52404;&#53356;&#48149;&#49828;&#32;&#52404;&#53356;&#47;&#48120;&#52404;&#53356;"/></tooltip>
                        </Button>
                            <Button text="&#8213;" onAction="#insertHorizontalRule" styleClass="toolbar-button notepad-format-command">
                            <tooltip><Tooltip text="&#49688;&#54217;&#49440;&#32;&#49341;&#51077;"/></tooltip>
                        </Button>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="6" styleClass="notepad-tool-group notepad-toggle-group">
                            <Label text="&#48372;&#44592;" styleClass="notepad-group-label"/>
                            <CheckBox fx:id="wrapTextCheckBox" text="&#51088;&#46041;&#32;&#51460;&#32;&#48148;&#45000;" selected="true" styleClass="notepad-wrap-toggle"/>
                        </HBox>
                    </HBox>
                </content>
            </ScrollPane>
        </VBox>
    </top>

    <center>
        <StackPane styleClass="notepad-workspace">
            <WebView fx:id="memoWebView" minHeight="360" prefHeight="520" styleClass="notepad-text-area"/>
            <Pane fx:id="visualBlockContainer" pickOnBounds="false" styleClass="visual-block-container"/>
        </StackPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="editor-footer">
            <padding>
                <Insets top="10" right="18" bottom="10" left="18"/>
            </padding>
            <Label fx:id="characterCountLabel" styleClass="stat-label"/>
            <Label text="|" styleClass="muted"/>
            <Label fx:id="noSpaceCountLabel" styleClass="stat-label"/>
            <Label text="|" styleClass="muted"/>
            <Label fx:id="lineCountLabel" styleClass="stat-label"/>
            <Label text="|" styleClass="muted"/>
            <Label fx:id="pointLabel" styleClass="stat-label"/>
            <Label text="|" styleClass="muted"/>
            <Label fx:id="zoomLabel" styleClass="stat-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="savedStateLabel" styleClass="stat-label"/>
        </HBox>
    </bottom>
</BorderPane>
